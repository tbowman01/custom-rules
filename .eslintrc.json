{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended",
    "@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "coverage/",
    "*.js"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": "error",
    "@typescript-eslint/no-explicit-any": "warn",
    "prefer-const": "error",
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["tests/unit/**/*.test.ts"],
      "rules": {
        "no-console": "error",
        "@typescript-eslint/no-explicit-any": "off"
      },
      "env": {
        "vitest/globals": true
      }
    },
    {
      "files": ["tests/integration/**/*.test.ts"],
      "env": {
        "vitest/globals": true
      }
    }
  ]
}
