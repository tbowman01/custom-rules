{
  "name": "@tbowman01/custom-rules",
  "version": "1.0.0",
  "description": "A customizable CLI tool for project rules validation and enforcement",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "custom-rules": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build",
    "start": "node dist/cli/main.js",
    "clean": "rm -rf dist/ node_modules/.cache"
  },
  "keywords": [
    "cli",
    "validation",
    "rules",
    "linting",
    "automation",
    "quality",
    "development",
    "typescript"
  ],
  "author": "tbowman01",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tbowman01/custom-rules.git"
  },
  "bugs": {
    "url": "https://github.com/tbowman01/custom-rules/issues"
  },
  "homepage": "https://github.com/tbowman01/custom-rules#readme",
  "files": [
    "dist/",
    "templates/",
    "profiles/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "yaml": "^2.3.0",
    "fs-extra": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "prettier": "^2.8.0"
  }
}
